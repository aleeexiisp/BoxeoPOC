---
interface Props {
  id?: string;
  text?: string;
  class?: string;
}
const { id = "stamp", text = "EST. 1934 · BARCELONA · BOXA · ", class: className = "" } = Astro.props;
const pathId = `${id}-path`;
---

<svg viewBox="0 0 200 200" class={className} aria-hidden="true">
  <defs>
    <path id={pathId} d="M 100,100 m -78,0 a 78,78 0 1,1 156,0 a 78,78 0 1,1 -156,0" />
  </defs>
  <circle cx="100" cy="100" r="96" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
  <circle cx="100" cy="100" r="60" fill="none" stroke="currentColor" stroke-width="1"></circle>
  <text font-family="Oswald, sans-serif" font-size="10.5" letter-spacing="2" fill="currentColor">
    <textPath href={`#${pathId}`} startOffset="0%">{text}{text}</textPath>
  </text>
  <path
    d="M100 78 L104.5 89 L116 89 L106.8 96 L110.3 107 L100 100 L89.7 107 L93.2 96 L84 89 L95.5 89 Z"
    fill="currentColor"
  ></path>
</svg>
