---
import { getDictionary, type Locale } from "../../i18n/utils";
import { asset } from "../../utils/asset";
import SectionHeader from "../SectionHeader.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDictionary(locale);

const photos = ["/img/gym/gym-5.jpg", "/img/gym/gym-3.jpg", "/img/gym/gym-1.jpg", "/img/gym/gym-2.jpg"];
---

<section id="galeria" class="relative bg-paper py-[clamp(5rem,10vw,9rem)]">
  <div class="mx-auto max-w-[1200px] px-6">
    <SectionHeader kicker={t.galeria.kicker} title={t.galeria.title} align="center" />

    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {
        photos.map((src, i) => (
          <div class="aspect-[3/4] overflow-hidden" data-reveal style={`--reveal-delay:${i * 100}ms`}>
            <img
              src={asset(src)}
              alt=""
              loading="lazy"
              class="h-full w-full object-cover shadow-poster transition-transform duration-500 hover:scale-105"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
