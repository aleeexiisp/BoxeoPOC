---
import { getDictionary, type Locale } from "../../i18n/utils";
import SectionHeader from "../SectionHeader.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDictionary(locale);
---

<section id="historia" class="relative bg-paper py-[clamp(5rem,10vw,9rem)]">
  <div class="mx-auto max-w-[1200px] px-6">
    <SectionHeader kicker={t.historia.kicker} title={t.historia.title} />

    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-5" data-reveal>
        {t.historia.paragraphs.map((p) => <p class="font-body text-lg leading-relaxed text-ink/85">{p}</p>)}
        <p class="pt-2 font-display text-2xl uppercase leading-tight text-oxblood md:text-3xl">{t.historia.quote}</p>
      </div>

      {/* Timeline */}
      <div class="relative pl-8" data-timeline data-reveal style="--reveal-delay:150ms">
        <span class="absolute left-0 top-0 h-full w-[2px] bg-oxblood/20" aria-hidden="true"></span>
        <span class="absolute left-0 top-0 h-full w-[2px] origin-top scale-y-0 bg-oxblood" data-timeline-progress aria-hidden="true"></span>
        {
          t.historia.timeline.map((item, i) => (
            <div class="relative pb-8 last:pb-0" data-reveal style={`--reveal-delay:${150 + i * 100}ms`}>
              <span class="absolute -left-[2.55rem] top-1 h-3 w-3 rounded-full border-2 border-oxblood bg-paper" />
              <p class="font-wood text-xl text-oxblood">{item.year}</p>
              <p class="mt-1 font-body text-sm text-ink/75">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
