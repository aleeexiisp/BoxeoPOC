---
import Kicker from "./Kicker.astro";
import DecoRule from "./DecoRule.astro";

interface Props {
  kicker: string;
  title: string;
  align?: "left" | "center";
  dark?: boolean;
  class?: string;
}
const { kicker, title, align = "left", dark = false, class: className = "" } = Astro.props;
const isCenter = align === "center";
---

<div class={`mb-12 md:mb-16 ${isCenter ? "text-center mx-auto max-w-2xl" : ""} ${className}`} data-reveal>
  <Kicker class={dark ? "text-gold" : "text-oxblood"}>{kicker}</Kicker>
  <h2
    class={`mt-3 font-display uppercase leading-[0.95] tracking-wide text-[clamp(2rem,4vw,3.25rem)] ${dark ? "text-paper" : "text-ink"}`}
  >
    {title}
  </h2>
  <DecoRule color={dark ? "text-gold" : "text-oxblood"} class={`mt-5 w-24 ${isCenter ? "mx-auto" : ""}`} />
</div>
