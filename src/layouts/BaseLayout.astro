---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getDictionary, localePath, LOCALES, type Locale } from "../i18n/utils";
import { asset } from "../utils/asset";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = getDictionary(locale);

const canonicalPath = Astro.url.pathname;
// TODO: sustituir por un cartel og-image dedicado (1200x630) cuando el club
// apruebe las imágenes históricas/de marca definitivas. De momento usamos el
// logo, que ya tiene una proporción cercana a la ideal de Open Graph.
const ogImage = new URL(asset("/img/logo-gran-price.png"), Astro.site ?? "https://aleeexiisp.github.io").toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <script is:inline>
      document.documentElement.classList.add("js-ready");
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={asset("/favicon.svg")} />
    <link rel="icon" href={asset("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />

    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />

    {LOCALES.map((l) => <link rel="alternate" hreflang={l} href={new URL(localePath(l, "/"), Astro.site).toString()} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(localePath("es", "/"), Astro.site).toString()} />
    <link rel="canonical" href={new URL(canonicalPath, Astro.site).toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale} />
    <meta name="twitter:card" content="summary_large_image" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SportsActivityLocation",
      name: "Boxa Gran Price",
      description: t.meta.description,
      address: {
        "@type": "PostalAddress",
        streetAddress: "Carrer d'Aragó 289",
        addressLocality: "Barcelona",
        postalCode: "08009",
        addressCountry: "ES",
      },
      telephone: ["+34648107610", "+34932659749"],
      sameAs: ["https://www.instagram.com/boxagranprice/", "https://www.facebook.com/boxagranprice/"],
    })} />
  </head>
  <body class="bg-paper font-body text-ink">
    <div id="curtain" class="fixed inset-0 z-[999] overflow-hidden bg-ink" aria-hidden="true">
      <img
        data-curtain-logo
        src={asset("/img/logo-gran-price.png")}
        alt=""
        class="absolute inset-0 h-full w-full object-cover grayscale contrast-125 opacity-0"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/60 to-ink/30"></div>
    </div>

    <Nav locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <script src="../scripts/animations.ts"></script>
  </body>
</html>
